# ---- Clawdmeter daemon (Docker, Linux host) ----
# Copy to .env and adjust. All keys are optional — sane defaults apply.

# Seed credentials: path on the HOST to the Claude credentials.json you copied
# from a machine where you ran `claude login`. Used once to seed the token
# volume; the refresher self-maintains it afterward. Default is ./secrets/.
CLAUDE_CREDENTIALS_FILE=./secrets/.credentials.json

# Token refresher tuning (seconds).
REFRESH_CHECK_INTERVAL=600   # how often to check the token (10 min)
REFRESH_MARGIN=1800          # refresh when fewer than this many seconds remain (30 min)
REFRESH_ON_START=true        # refresh once at startup to validate + maximize runway

# USB-serial transport (start.sh -t usb): the device's serial port on the host.
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200
# Screen auto-sleep timeout in seconds, pushed to the device on connect.
# Blank = leave the device's saved value; 0 = never sleep. e.g. 600 = 10 min.
SCREEN_SLEEP_SECONDS=

# Override ONLY if the upstream OAuth details change.
# CLAUDE_OAUTH_TOKEN_URL=https://console.anthropic.com/v1/oauth/token
# CLAUDE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
