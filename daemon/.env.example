# ---- Clawdmeter daemon (Docker) ----
# Copy to .env and adjust. Both keys are optional — sane defaults apply.

# Compose project name. The container is named <project>-daemon.
COMPOSE_PROJECT_NAME=clawdmeter

# Absolute path on the HOST to your Claude Code config dir (the one holding
# .credentials.json, written by `claude login`). Mounted read-only into the
# container. Defaults to $HOME/.claude if left unset.
# CLAUDE_CONFIG_DIR=/home/youruser/.claude
